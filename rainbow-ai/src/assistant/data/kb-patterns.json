{
  "description": "Knowledge base topic file mappings for Makan Moments Cafe. Patterns are regex alternations tested case-insensitively against user messages.",
  "coreFiles": ["cafe-facts.md"],
  "defaultFallback": "faq.md",
  "patterns": [
    {
      "comment": "Menu & food items",
      "regex": "menu|food|dish|eat|makan|makanan|order|ada apa|apa ada|what.*food|tomyam|tom yum|nasi|mee|noodle|rice|chicken|ayam|ikan|fish|vege|sayur|dessert|ice cream|drink|minum|minuman|饮料|菜单|吃什么",
      "files": ["menu.md"]
    },
    {
      "comment": "Pricing & cost",
      "regex": "price|cost|rate|how much|berapa|harga|murah|mahal|多少|rm\\d|ringgit",
      "files": ["menu.md"]
    },
    {
      "comment": "Pre-order & ordering process",
      "regex": "pre.?order|preorder|order online|tempah|how.?to.?order|submit.?order|place.?order|order.?status|my.?order|cancel.?order|t&g|touch.?n.?go|tng|deposit|payment|bayar|pay",
      "files": ["ordering.md"]
    },
    {
      "comment": "Dietary & halal",
      "regex": "halal|pork|babi|lard|vegetarian|vege|vegan|allerg|dietary|no.*pork|清真|素食",
      "files": ["cafe-facts.md"]
    },
    {
      "comment": "Cafe info — location & hours",
      "regex": "where|location|address|direction|how.?to.?get|map|open|close|hour|operating|masa|buka|tutup|alamat|地址|营业|几点",
      "files": ["cafe-facts.md"]
    },
    {
      "comment": "WiFi",
      "regex": "wifi|internet|password|网络|密码",
      "files": ["cafe-facts.md"]
    },
    {
      "comment": "Reservations & table booking",
      "regex": "reserv|book.*table|table.*book|sit|seating|meja|tempah.*meja|预订|座位",
      "files": ["ordering.md"]
    },
    {
      "comment": "General FAQ",
      "regex": "faq|question|info|about|contact|whatsapp|phone|social|instagram|facebook|tiktok",
      "files": ["faq.md"]
    }
  ]
}
