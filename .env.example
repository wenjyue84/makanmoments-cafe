# Database (Neon Serverless Postgres)
DATABASE_URL=postgresql://user:pass@host.neon.tech/dbname?sslmode=require

# Admin Authentication
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-strong-password-here
ADMIN_JWT_SECRET=at-least-32-chars-random-secret

# AI Waiter
GROQ_API_KEY=gsk_xxx
OPENROUTER_API_KEY=sk-or-xxx

# Site
NEXT_PUBLIC_SITE_URL=https://makanmoments.cafe

# WhatsApp CTA (optional)
NEXT_PUBLIC_WHATSAPP_NUMBER=

# PWA Push Notifications (generate with: node -e "const wp=require('web-push'); console.log(wp.generateVAPIDKeys())")
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:admin@makanmoments.cafe

# REMOVED — Notion no longer used:
# NOTION_API_KEY
# NOTION_MENU_DB_ID
# NOTION_BLOG_DB_ID
